# Server
PORT=8090

# Database — point at your Postgres host
DATABASE_URL=postgres://USER:PASSWORD@DB_HOST:5432/rpk_food?sslmode=require

# Auth
JWT_SECRET=change_me_to_a_long_random_string

# Claude API (for the AI chatbot). Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# CORS — comma separated allowed origins for the web app
CORS_ORIGINS=https://your-domain.com
