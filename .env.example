# Copy to .env on the VPS and fill in real values:  cp .env.example .env
# docker compose -f docker-compose.prod.yml reads .env automatically.

# --- Database ---
POSTGRES_USER=rpk
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=rpk_food

# --- Backend ---
# Long random string used to sign login tokens. Generate one, e.g.:
#   openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string

# Optional: enables the AI chatbot. Leave blank to use the canned fallback reply.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Same-origin in this setup, so "*" is fine. Tighten to your domain if you ever
# expose the backend directly: https://yourdomain.com
CORS_ORIGINS=*

# --- Web ---
# Host port the site is published on. 80 = http://<vps-ip>/
WEB_PORT=80
